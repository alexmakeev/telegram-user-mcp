# Telegram User MCP — environment variables template
# Real values are managed in Dokploy, NOT in this file.
#
# NEVER create a .env file locally — use Dokploy environment UI.
# The container requires DEPLOY_CONFIRMED_BY_ADMIN=yes (set in Dokploy only).

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=telegram_user
TELEGRAM_SESSION_DIR=/app/sessions
DEPLOY_CONFIRMED_BY_ADMIN=yes
LOG_LEVEL=INFO
